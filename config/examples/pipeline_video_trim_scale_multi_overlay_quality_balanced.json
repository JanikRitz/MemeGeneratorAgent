{
  "pipeline": [
    {
      "operation": "trim_video",
      "params": {
        "input_path": "media/examples/video.mp4",
        "start_sec": 1.0,
        "end_sec": 6.0,
        "output_path": "render/examples/video_trimmed_balanced.mp4",
        "video_crf": 28,
        "video_preset": "fast",
        "video_bitrate": "1400k",
        "audio_bitrate": "96k"
      }
    },
    {
      "operation": "scale_media",
      "params": {
        "input_path": "$last_output",
        "output_path": "render/examples/video_trimmed_720_balanced.mp4",
        "max_long_side": 720,
        "upscale": false,
        "video_crf": 30,
        "video_preset": "fast",
        "video_bitrate": "1200k",
        "audio_bitrate": "96k"
      }
    },
    {
      "operation": "apply_multi_text_overlays",
      "params": {
        "base_media_path": "$last_output",
        "output_path": "render/examples/video_trim_scale_overlay_balanced.mp4",
        "video_crf": 30,
        "video_preset": "fast",
        "video_bitrate": "1100k",
        "audio_bitrate": "96k",
        "overlays": [
          {
            "overlay_name": "trim_scale_top_balanced",
            "text": "**BALANCED QUALITY**",
            "start_time": 0.0,
            "end_time": 5.0,
            "match_base_size": true,
            "text_align": "center",
            "text_vertical_align": "top",
            "text_padding": 10,
            "font_size": 24,
            "stroke_width": 3,
            "stroke_fill": "#000000",
            "shadow_enabled": true
          },
          {
            "overlay_name": "trim_scale_bottom_balanced",
            "text": "<span style=\"color:#00ccff\"><i>middle ground for share size + legibility</i></span>",
            "start_time": 2.0,
            "end_time": 5.0,
            "match_base_size": true,
            "text_align": "center",
            "text_vertical_align": "bottom",
            "text_padding": 10,
            "font_size": 22,
            "stroke_width": 3,
            "stroke_fill": "#000000",
            "shadow_enabled": true
          }
        ]
      }
    }
  ]
}
