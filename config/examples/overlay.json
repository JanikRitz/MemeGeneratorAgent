{
  "operation": "apply_multi_text_overlays",
  "params": {
    "base_media_path": "media/examples/video.mp4",
    "output_path": "render/examples/overlayed.mp4",
    "overlays": [
      {
        "overlay_name": "headline",
        "text": "*TOP TEXT* WOW",
        "start_time": 0.0,
        "end_time": 4.5,
        "text_align": "center",
        "text_vertical_align": "top",
        "text_padding": 6,
        "font_size": 52
      },
      {
        "overlay_name": "subline",
        "text": "<span style=\"color:#00ccff\"><i>bottom text</i></span>",
        "start_time": 3.5,
        "end_time": 7.0,
        "text_align": "center",
        "text_vertical_align": "bottom",
        "text_padding": 6,
        "font_size": 52
      }
    ]
  }
}
