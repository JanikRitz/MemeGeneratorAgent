{
  "pipeline": [
    {
      "operation": "trim_video",
      "params": {
        "input_path": "media/examples/video.mp4",
        "start_sec": 1.0,
        "end_sec": 6.0,
        "output_path": "render/examples/video_trimmed.mp4"
      }
    },
    {
      "operation": "scale_media",
      "params": {
        "input_path": "$last_output",
        "output_path": "render/examples/video_trimmed_640_max.mp4",
        "max_long_side": 640,
        "upscale": false,
        "video_crf": 34,
        "video_preset": "fast",
        "video_bitrate": "900k",
        "audio_bitrate": "64k"
      }
    },
    {
      "operation": "apply_multi_text_overlays",
      "params": {
        "base_media_path": "$last_output",
        "output_path": "render/examples/video_trim_scale_overlay.mp4",
        "video_crf": 36,
        "video_preset": "fast",
        "video_bitrate": "900k",
        "audio_bitrate": "64k",
        "overlays": [
          {
            "overlay_name": "trim_scale_top",
            "text": "**TRIM + SCALE + OVERLAY**",
            "start_time": 0.0,
            "end_time": 5.0,
            "match_base_size": true,
            "text_align": "center",
            "text_vertical_align": "top",
            "text_padding": 10,
            "font_size": 24,
            "stroke_width": 3,
            "stroke_fill": "#000000",
            "shadow_enabled": true
          },
          {
            "overlay_name": "trim_scale_bottom",
            "text": "<span style=\"color:#00ccff\"><i>640 max-long-side target</i></span>",
            "start_time": 2.2,
            "end_time": 5.0,
            "match_base_size": true,
            "text_align": "center",
            "text_vertical_align": "bottom",
            "text_padding": 10,
            "font_size": 24,
            "stroke_width": 3,
            "stroke_fill": "#000000",
            "shadow_enabled": true
          }
        ]
      }
    }
  ]
}
