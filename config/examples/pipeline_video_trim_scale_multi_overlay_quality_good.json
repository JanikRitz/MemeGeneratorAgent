{
  "pipeline": [
    {
      "operation": "trim_video",
      "params": {
        "input_path": "media/examples/video.mp4",
        "start_sec": 1.0,
        "end_sec": 6.0,
        "output_path": "render/examples/video_trimmed_good.mp4",
        "video_crf": 20,
        "video_preset": "slow",
        "video_bitrate": "3500k",
        "audio_bitrate": "160k"
      }
    },
    {
      "operation": "scale_media",
      "params": {
        "input_path": "$last_output",
        "output_path": "render/examples/video_trimmed_1280_good.mp4",
        "max_long_side": 1280,
        "upscale": false,
        "video_crf": 20,
        "video_preset": "slow",
        "video_bitrate": "3000k",
        "audio_bitrate": "160k"
      }
    },
    {
      "operation": "apply_multi_text_overlays",
      "params": {
        "base_media_path": "$last_output",
        "output_path": "render/examples/video_trim_scale_overlay_good.mp4",
        "video_crf": 19,
        "video_preset": "slow",
        "video_bitrate": "3000k",
        "audio_bitrate": "160k",
        "overlays": [
          {
            "overlay_name": "trim_scale_top_good",
            "text": "**RELATIVELY GOOD QUALITY**",
            "start_time": 0.0,
            "end_time": 5.0,
            "match_base_size": true,
            "text_align": "center",
            "text_vertical_align": "top",
            "text_padding": 10,
            "font_size": 26,
            "stroke_width": 3,
            "stroke_fill": "#000000",
            "shadow_enabled": true
          },
          {
            "overlay_name": "trim_scale_bottom_good",
            "text": "<span style=\"color:#00ccff\"><i>cleaner encode, still meme-ready</i></span>",
            "start_time": 2.0,
            "end_time": 5.0,
            "match_base_size": true,
            "text_align": "center",
            "text_vertical_align": "bottom",
            "text_padding": 10,
            "font_size": 24,
            "stroke_width": 3,
            "stroke_fill": "#000000",
            "shadow_enabled": true
          }
        ]
      }
    }
  ]
}
