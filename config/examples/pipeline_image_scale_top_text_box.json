{
  "pipeline": [
    {
      "operation": "scale_media",
      "params": {
        "input_path": "media/examples/image.jpeg",
        "output_path": "render/examples/image_1080_max.jpeg",
        "max_long_side": 1080,
        "upscale": false
      }
    },
    {
      "operation": "add_text_side_box",
      "params": {
        "base_media_path": "$last_output",
        "text_data": "[color=#000000]Girls be Girls[/color]",
        "side": "top",
        "output_path": "render/examples/image_top_box_1080.png",
        "background_color": "#ff69b4",
        "text_align": "center",
        "text_vertical_align": "center",
        "text_padding": 16,
        "font_size": 72,
        "stroke_width": 0,
        "shadow_enabled": false,
        "auto_size": true,
        "panel_png_name": "image_top_pink_panel_1920"
      }
    }
  ]
}
