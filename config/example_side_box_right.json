    "box_size_ratio": 0.28,
    "background_color": "#155ca2",
    "text_align": "left",
    "text_vertical_align": "center",
    "text_padding": 12,
    "font_size": 23,
    "line_height": 0.82,
    "stroke_width": 2,
    "stroke_fill": "#000000",
    "shadow_enabled": true,
    "panel_png_name": "right_panel.png"
  }
}
