{
  "operation": "apply_multi_text_overlays",
  "params": {
    "base_media_path": "media/base.mp4",
    "output_path": "render/overlayed.mp4",
    "overlay_dir": "render",
    "overlays": [
      {
        "overlay_name": "headline.png",
        "text": "**TOP TEXT** [color=#ff3333]wow[/color]",
        "start_time": 0.0,
        "end_time": 3.5,
        "position": ["center", "top"],
        "width": 1280,
        "height": 220,
        "text_align": "center",
        "text_vertical_align": "center",
        "text_padding": 24,
        "font_size": 72,
        "stroke_width": 4,
        "stroke_fill": "#000000",
        "shadow_enabled": true
      },
      {
        "overlay_name": "subline.png",
        "text": "<span style=\"color:#00ccff\"><i>bottom text</i></span>",
        "start_time": 3.5,
        "end_time": 7.0,
        "position": ["center", "bottom"],
        "width": 1280,
        "height": 220,
        "text_align": "center",
        "text_vertical_align": "center",
        "text_padding": 24,
        "font_size": 64,
        "stroke_width": 4,
        "stroke_fill": "#000000",
        "shadow_enabled": true
      }
    ]
  }
}
